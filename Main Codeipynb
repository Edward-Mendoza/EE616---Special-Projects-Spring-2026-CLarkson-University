        "    print(\"Face detection model downloaded.\")\n",
        "\n",
        "face_cascade = cv2.CascadeClassifier(cascade_path)\n",
        "\n",
        "\n",
        "def detect_face_opencv(img, face_cascade):\n",
        "    \"\"\"\n",
        "    Detects the largest face in an image using OpenCV's Haar Cascade detector.\n",
        "    Returns (x_min, y_min, x_max, y_max) in pixel coordinates,\n",
        "    or None if no face is found.\n",
        "\n",
        "    Haar Cascade works by sliding a window across the image and checking\n",
        "    whether each region looks like a face based on patterns it learned\n",
        "    during training. It is less accurate than MediaPipe on tilted or\n",
        "    partially occluded faces, but requires no extra dependencies.\n",
        "    \"\"\"\n",
        "    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
        "\n",
        "    detections = face_cascade.detectMultiScale(\n",
        "        gray,\n",
        "        scaleFactor=1.1,   # how much the image is scaled down each pass\n",
        "        minNeighbors=5,    # how many overlapping detections needed to confirm a face\n",
        "        minSize=(30, 30)   # minimum face size in pixels to detect\n",
        "    )\n",
        "\n",
        "    if len(detections) == 0:\n",
        "        return None\n",
        "\n",
        "    # --- Pick the largest detected face by area ---\n",
        "    x, y, fw, fh = max(detections, key=lambda d: d[2] * d[3])\n",
        "    return x, y, x + fw, y + fh\n",
