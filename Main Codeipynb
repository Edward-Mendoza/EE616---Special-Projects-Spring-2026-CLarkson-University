      "source": [
        "'''\n",
        "# Create images for margins group test\n",
        "# Detects face bounding box, randomly crops between 0 and n pixels from each edge\n",
        "# where n is the gap between the bounding box and the image edge\n",
        "# inputs  - google drive folder containing images\n",
        "# outputs - altered images saved back to the same folder with a suffix\n",
        "\n",
        "# --- Mount drive if not already mounted ---\n",
        "if not os.path.exists('/content/drive/MyDrive'):\n",
        "    drive.mount('/content/drive')\n",
        "\n",
        "# --- Check mediapipe is available before proceeding ---\n",
        "try:\n",
        "    import mediapipe as mp\n",
        "except ImportError:\n",
