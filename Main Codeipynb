        "# Create images for brightness group test\n",
        "# Selects images and randomly changes brightness between min and max factor\n",
        "# inputs  - google drive folder OR local PC folder containing images, brightness parameters\n",
        "# outputs - altered images saved to a '_altered' subfolder in the same location\n",
        "\n",
        "def detect_and_mount_drive(folder_path):\n",
        "    \"\"\"\n",
        "    Checks if the path looks like a Google Drive path.\n",
        "    If so, mounts drive if not already mounted.\n",
        "    Returns True if drive path, False if local path.\n",
        "    \"\"\"\n",
        "    is_drive_path = folder_path.startswith('/content/drive')\n",
        "\n",
        "    if is_drive_path:\n",
        "        if not os.path.exists('/content/drive/MyDrive'):\n",
        "            drive.mount('/content/drive')\n",
        "            print(\"Google Drive mounted.\")\n",
        "        else:\n",
        "            print(\"Google Drive already mounted.\")\n",
        "    return is_drive_path\n",
        "\n",
        "\n",
        "def get_output_folder(folder_path, is_drive_path, output_suffix):\n",
        "    \"\"\"\n",
        "    Determines where to save altered images based on input type.\n",
        "    - Drive path: saves into a subfolder inside the same Drive folder\n",
        "    - Local path: creates a new folder on the PC next to the input folder\n",
        "    \"\"\"\n",
        "    parent_dir = os.path.dirname(folder_path)\n",
        "    folder_name = os.path.basename(folder_path)\n",
        "\n",
        "    if is_drive_path:\n",
        "        # Save into a subfolder inside the Drive folder\n",
        "        output_dir = os.path.join(folder_path, f\"altered{output_suffix}\")\n",
        "        print(f\"Output will be saved to Drive subfolder: '{output_dir}'\")\n",
        "    else:\n",
        "        # Save into a new folder next to the input folder on the PC\n",
        "        output_dir = os.path.join(parent_dir, f\"{folder_name}_altered{output_suffix}\")\n",
        "        print(f\"Output will be saved to local folder: '{output_dir}'\")\n",
        "\n",
        "    # --- Create the output folder if it doesn't exist ---\n",
        "    os.makedirs(output_dir, exist_ok=True)\n",
        "    return output_dir\n",
        "\n",
        "\n",
        "def randomize_luminance(folder_path, min_factor=0.6, max_factor=1.4, output_suffix='_lum',\n",
        "                        file_extensions=('jpg', 'jpeg', 'png')):\n",
        "    \"\"\"\n",
        "    Randomly adjusts brightness of every image in folder_path by a factor\n",
        "    between min_factor and max_factor. A factor below 1.0 darkens the image,\n",
        "    above 1.0 brightens it.\n",
        "\n",
        "    Automatically detects whether folder_path is a Google Drive path or a\n",
        "    local PC path, and saves altered images to the appropriate output location.\n",
        "    Originals are never overwritten.\n",
        "    \"\"\"\n",
        "\n",
        "    # --- Validate inputs before doing any work ---\n",
        "    if min_factor < 0 or max_factor < 0 or min_factor > max_factor:\n",
        "        raise ValueError(\"Bounds must be non-negative and min_factor must be <= max_factor.\")\n",
        "\n",
        "    # --- Detect path type and mount drive if needed ---\n",
        "    is_drive_path = detect_and_mount_drive(folder_path)\n",
        "\n",
        "    if not os.path.exists(folder_path):\n",
        "        raise FileNotFoundError(f\"Folder not found: '{folder_path}'. Check the path and try again.\")\n",
        "\n",
        "    # --- Determine output folder based on path type ---\n",
        "    output_dir = get_output_folder(folder_path, is_drive_path, output_suffix)\n",
        "\n",
        "    processed = 0\n",
        "    skipped = 0\n",
        "\n",
        "    for fname in os.listdir(folder_path):\n",
        "\n",
        "        # --- Skip files that aren't images ---\n",
        "        base, ext = os.path.splitext(fname)\n",
        "        if ext.lower().lstrip('.') not in file_extensions:\n",
        "            continue\n",
        "\n",
        "        # --- Skip files that are already altered copies ---\n",
        "        if output_suffix in base:\n",
        "            print(f\"Skipping already-altered file: '{fname}'\")\n",
        "            continue\n",
        "\n",
        "        in_path = os.path.join(folder_path, fname)\n",
        "        img = cv2.imread(in_path)\n",
        "\n",
        "        if img is None:\n",
        "            print(f\"Could not read '{fname}', skipping.\")\n",
        "            skipped += 1\n",
        "            continue\n",
        "\n",
        "        # --- Convert to HSV and adjust the V (brightness) channel ---\n",
        "        # HSV stands for Hue, Saturation, Value — Value is brightness\n",
        "        hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV).astype('float32')\n",
        "        factor = random.uniform(min_factor, max_factor)\n",
        "        hsv[..., 2] = (hsv[..., 2] * factor).clip(0, 255)\n",
        "\n",
        "        # --- Convert back to BGR (standard colour format for saving) ---\n",
        "        new_img = cv2.cvtColor(hsv.astype('uint8'), cv2.COLOR_HSV2BGR)\n",
        "\n",
        "        # --- Save altered image to the output folder ---\n",
        "        out_fname = f\"{base}{output_suffix}{ext}\"\n",
        "        out_path  = os.path.join(output_dir, out_fname)\n",
        "        cv2.imwrite(out_path, new_img)\n",
        "        print(f\"Saved '{out_fname}' (brightness factor = {factor:.3f})\")\n",
        "        processed += 1\n",
        "\n",
        "    print(f\"\\nDone. {processed} images altered, {skipped} skipped.\")\n",
        "    print(f\"Altered images saved to: {output_dir}\")\n",
        "\n",
        "\n",
        "# --- Get inputs from user ---\n",
        "print(\"Enter the full path to your folder:\")\n",
        "print(\"  Google Drive example : /content/drive/MyDrive/images\")\n",
        "print(\"  Local PC example     : C:/Users/YourName/Pictures/images\")\n",
        "folder = input().strip()\n",
        "\n",
        "print(\"\\nEnter minimum brightness multiplier (default 0.6 = 40% darker):\")\n",
        "min_f = float(input().strip() or 0.6)\n",
        "\n",
        "print(\"Enter maximum brightness multiplier (default 1.4 = 40% brighter):\")\n",
        "max_f = float(input().strip() or 1.4)\n",
        "\n",
        "print(\"Enter suffix for output files (default '_lum'):\")\n",
        "suffix = input().strip() or '_lum'\n",
        "\n",
        "randomize_luminance(\n",
        "    folder_path=folder,\n",
        "    min_factor=min_f,\n",
        "    max_factor=max_f,\n",
        "    output_suffix=suffix\n",
        ")"
      ],
