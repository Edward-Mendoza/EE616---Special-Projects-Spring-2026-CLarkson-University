        "def pca_training_and_verification_2c(data):\n",
        "\n",
        "    groups = {\n",
        "        'brightness_group': [\n",
        "            'DynamicRange.scalar',\n",
        "            'LuminanceMean.scalar',\n",
        "            'LuminanceVariance.scalar'\n",
        "        ],\n",
        "        'occlusion_group': [\n",
        "            'FaceOcclusionPrevention.scalar',\n",
        "            'EyesVisible.scalar',\n",
        "            'MouthOcclusionPrevention.scalar'\n",
        "        ],\n",
        "        'margin_group': [\n",
        "            'MarginAboveOfTheFaceImage.scalar',\n",
        "            'MarginBelowOfTheFaceImage.scalar',\n",
        "            'HeadSize.scalar'\n",
        "        ]\n",
        "    }\n",
        "\n",
        "    pca_models = {}\n",
        "\n",
        "    for group_name, cols in groups.items():\n",
        "\n",
        "        # --- Changed: n_components=2 to capture more variance ---\n",
        "        pca = PCA(n_components=2)\n",
        "        components = pca.fit_transform(data[cols])\n",
        "\n",
        "        # --- Changed: store pc1 and pc2 as separate columns ---\n",
        "        data[f\"{group_name}_pc1\"] = components[:, 0]\n",
        "        data[f\"{group_name}_pc2\"] = components[:, 1]\n",
        "\n",
        "        pca_models[group_name] = pca\n",
        "\n",
        "        # --- Changed: report variance for both components ---\n",
        "        pc1_pct = pca.explained_variance_ratio_[0] * 100\n",
        "        pc2_pct = pca.explained_variance_ratio_[1] * 100\n",
        "        total_pct = pc1_pct + pc2_pct\n",
        "        print(f\"Group '{group_name}':\")\n",
        "        print(f\"  PC1 explains {pc1_pct:.2f}% | PC2 explains {pc2_pct:.2f}% | Total: {total_pct:.2f}%\")\n",
        "\n",
        "    # --- Changed: collect both pc1 and pc2 columns for scaling ---\n",
        "    pc_cols = []\n",
        "    for g in groups:\n",
        "        pc_cols.append(f\"{g}_pc1\")\n",
        "        pc_cols.append(f\"{g}_pc2\")\n",
        "\n",
        "    print(\"\\nPreview of composite features:\")\n",
        "    print(data[pc_cols].head())\n",
        "\n",
        "    # Scale all 6 PCA columns to 0-1\n",
        "    scaled_cols = [f\"{col}_scaled\" for col in pc_cols]\n",
        "    scaler = MinMaxScaler(feature_range=(0, 1))\n",
        "    data[scaled_cols] = scaler.fit_transform(data[pc_cols])\n",
        "\n",
        "    print(\"\\nPreview of scaled composite features:\")\n",
        "    print(data[scaled_cols].head())\n",
        "\n",
        "    # Save updated CSV\n",
        "    new_csv_path = 'ofiq_with_pca2_data.csv'\n",
        "    data.to_csv(new_csv_path, index=False)\n",
        "    files.download(new_csv_path)\n",
        "\n",
        "    # Save each PCA model\n",
        "    for group_name, pca in pca_models.items():\n",
        "        model_filename = f\"{group_name}_pca2.joblib\"\n",
        "        joblib.dump(pca, model_filename)\n",
        "        files.download(model_filename)\n",
        "\n",
        "    # --- New: save the scaler too (important for test data later) ---\n",
        "    joblib.dump(scaler, 'minmax_scaler_pca2.joblib')\n",
        "    files.download('minmax_scaler_pca2.joblib')\n",
        "\n",
        "    print(\"All PCA models and scaler saved.\")\n",
        "\n",
        "\n",
        "uploaded = files.upload()\n",
        "fname = list(uploaded.keys())[0]\n",
        "training_csv_data = pd.read_csv(io.BytesIO(uploaded[fname]))\n",
        "pca_training_and_verification_2c(training_csv_data)"
